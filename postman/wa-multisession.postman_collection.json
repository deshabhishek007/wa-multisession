{
  "info": {
    "name": "WhatsApp Multi-Instance API",
    "description": "API for wa-multisession. Run **Login** first to set session cookie; then use other endpoints. For instance API key auth, set `instanceApiKey` and `instanceId` variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "instanceId", "value": "client1" },
    { "key": "instanceApiKey", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/login",
            "description": "Log in. Session cookie is stored automatically for subsequent requests."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/logout",
            "description": "Destroy session."
          }
        },
        {
          "name": "Check auth",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/check-auth",
            "description": "Returns authenticated flag and user if logged in."
          }
        },
        {
          "name": "Get current user (me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/me",
            "description": "Requires session (run Login first)."
          }
        }
      ]
    },
    {
      "name": "Instances",
      "item": [
        {
          "name": "List instances",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/instances",
            "description": "Requires session. Admin sees all; users see assigned only."
          }
        },
        {
          "name": "Create instance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instanceId\": \"client1\"\n}"
            },
            "url": "{{baseUrl}}/api/instances",
            "description": "Admin only."
          }
        },
        {
          "name": "Delete instance",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/instances/{{instanceId}}",
            "description": "Admin only."
          }
        }
      ]
    },
    {
      "name": "Instance (by ID)",
      "item": [
        {
          "name": "Get API key",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{instanceApiKey}}", "disabled": true }
            ],
            "url": "{{baseUrl}}/api/instances/{{instanceId}}/api-key",
            "description": "Session or X-API-Key. Creates key if missing."
          }
        },
        {
          "name": "Regenerate API key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{instanceApiKey}}", "disabled": true }
            ],
            "url": "{{baseUrl}}/api/instances/{{instanceId}}/api-key/regenerate",
            "description": "Session or X-API-Key. Old key stops working."
          }
        },
        {
          "name": "Send message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{instanceApiKey}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"919876543210\",\n  \"message\": \"Hello from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/instances/{{instanceId}}/send-message",
            "description": "Session or X-API-Key. `to` = digits with country code, no + or spaces."
          }
        },
        {
          "name": "List users for instance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/instances/{{instanceId}}/users",
            "description": "Admin only."
          }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users",
            "description": "Admin only."
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"agent1\",\n  \"password\": \"secret123\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Admin only. role: 'user' or 'admin'."
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/2",
            "description": "Admin only. Cannot delete self or last admin."
          }
        },
        {
          "name": "Change user password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/users/2/password",
            "description": "Admin only."
          }
        },
        {
          "name": "List user's instances",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/2/instances",
            "description": "Admin only. Returns instance IDs assigned to user 2."
          }
        },
        {
          "name": "Assign instance to user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instanceId\": \"client1\"\n}"
            },
            "url": "{{baseUrl}}/api/users/2/instances",
            "description": "Admin only."
          }
        },
        {
          "name": "Remove instance from user",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/2/instances/{{instanceId}}",
            "description": "Admin only."
          }
        }
      ]
    }
  ]
}
